# ==============================================================================
# MANDATORY: CMake & Build Artifacts
# ==============================================================================
# Ignore the entire build directory where binaries, object files, and temporary
# compilation files are stored.
[Bb]uild/
[Bb]uild-*/

# Ignore direct binary output expansions if generated outside the build folder
*.exe
*.out
*.app
*.a
*.o
*.obj
*.lib
*.dll
*.so
*.dylib

# CMake specific system cache files (incase cmake runs in the root directory by mistake)
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json

# ==============================================================================
# IDE Specific Configuration Files (Optional but highly recommended)
# ==============================================================================
# VS Code
.vscode/
!.vscode/extensions.json
*.code-workspace

# JetBrains CLion / Rider / IntelliJ
.idea/
*.iws

# Microsoft Visual Studio (MSBuild & Visual Studio IDE artifacts)
.vs/
*.user
*.suo
*.sln
*.vcxproj
*.filters

# Xcode (macOS)
*.xcodeproj/
*.xcworkspace/
DerivedData/

# ==============================================================================
# Operating System Junk
# ==============================================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.fuse_hidden*
.directory
.trash/

# ==============================================================================
# Testing & Diagnostic Outputs (For future profiling/testing runs)
# ==============================================================================
*.log
*.tlog
*.lastbuildstate


